<Application x:Class="BlockifyLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BlockifyLauncher"
             xmlns:view="clr-namespace:BlockifyLauncher.MVVM.Views.Pages"
             xmlns:viewModel="clr-namespace:BlockifyLauncher.MVVM.ViewModel.Pages"
             StartupUri="MVVM/Views/Window/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MVVM/Views/Style/ApplicationStyle.xaml"/>
                <ResourceDictionary Source="MVVM/Views/Style/CustomElement.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewModel:MainModel}">
                <view:MainPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewModel:SettingModel}">
                <view:SettingPage/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
