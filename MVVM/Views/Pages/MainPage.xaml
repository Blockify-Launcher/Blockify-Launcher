<Page x:Class="BlockifyLauncher.MVVM.Views.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BlockifyLauncher.MVVM.Views.Pages"
      xmlns:controls="clr-namespace:BlockifyLauncher.MVVM.Views.Style.Effect"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="70*"/>
        </Grid.RowDefinitions>

        <Border CornerRadius="15" Background="#7F262626" BorderBrush="#3F5A5A5A" BorderThickness="1">
            <StackPanel>
                <Label Content="Test text" FontSize="32" Foreground="White"/>
            </StackPanel>
        </Border>

        <controls:WindowBlur x:Name="BlurBackground" BlurContainer="{Binding ElementName=InnerBlurContainer}" BlurRadius="45" Magnification="0.25" />
        <Border CornerRadius="15" Background="#7F262626" Grid.Row="1"
                Margin="0,20,0,0" BorderBrush="#3F5A5A5A" BorderThickness="1">
            <StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
